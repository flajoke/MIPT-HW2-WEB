        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"customer_name\": \"Иван Иванов\",\n  \"phone\": \"+79990000000\",\n  \"email\": \"ivan@example.com\",\n  \"city\": \"Москва\",\n  \"address\": \"ул. Ленина, д. 1\",\n  \"comment\": \"Позвонить за час\",\n  \"delivery_cost\": 0\n}"
        }
      },
      "response": []
