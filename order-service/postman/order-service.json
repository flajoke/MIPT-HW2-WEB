            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "description": "Оформление заказа",
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders"
          ]
