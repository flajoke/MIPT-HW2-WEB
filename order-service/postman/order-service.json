      "name": "GET /api/v1/carts/{sessionId}",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Получение активной корзины",
        "url": {
          "raw": "{{baseUrl}}/api/v1/carts/{{sessionId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carts",
            "{{sessionId}}"
          ]
        }
      },
      "response": []
